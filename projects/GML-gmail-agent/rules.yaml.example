# GML rules — archive rules applied by `gml run` and the `gml serve` scheduler
# Each rule is evaluated independently. Use --dry-run to preview before running.
#
# Rule types:
#   archive_by_age:    archive messages older than N days
#   archive_by_sender: archive messages from matching sender patterns
#   archive_by_label:  archive messages with a given Gmail label
#
# state (archive_by_age): read | unread | any (default: read)

# Access mode: "readonly" (default) or "readwrite"
# readonly:  stats, profile, and dry-run work; actual archiving is blocked
# readwrite: enables archiving — also requires re-running setup.sh without --readonly
mode: readonly

# Rules daemon scheduling
schedule:
  lookback_hours: 72
  interval_minutes: 360   # run rules every 6 hours

rules:
  # Rules will be populated by the knowledge pipeline (propose → approve → apply-rules).
  # You can also add rules manually. Examples:
  #
  # - name: "old promotions"
  #   type: archive_by_age
  #   params:
  #     days: 30
  #     state: read
  #     label: CATEGORY_PROMOTIONS
  #
  # - name: "noreply senders"
  #   type: archive_by_sender
  #   params:
  #     senders:
  #       - noreply@example.com
